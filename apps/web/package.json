{
  "name": "inbox-zero-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max_old_space_size=6144 next dev --turbopack",
    "dev:e2e": "dotenv -e .env.e2e -- cross-env NODE_OPTIONS=--max_old_space_size=6144 next dev --turbopack",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=16384 prisma migrate deploy && next build",
    "build:ci": "cross-env NODE_OPTIONS=--max_old_space_size=16384 next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "biome check .",
    "check-enums": "node scripts/check-enum-imports.js",
    "check-server-actions": "node scripts/check-server-action-exports.js",
    "generate-llm-pricing": "tsx scripts/generate-llm-pricing.ts",
    "test": "cross-env RUN_AI_TESTS=false vitest",
    "test-ai": "cross-env RUN_AI_TESTS=true vitest --run",
    "test-e2e": "cross-env RUN_E2E_TESTS=true vitest --run",
    "test-integration": "cross-env RUN_INTEGRATION_TESTS=true vitest --run --dir __tests__/integration",
    "test-e2e:flows": "cross-env RUN_E2E_FLOW_TESTS=true vitest --run --dir __tests__/e2e/flows --no-file-parallelism",
    "test:smoke": "playwright test -c playwright.smoke.config.mjs",
    "emulate:google": "emulate --service google --seed ../../emulate.config.yaml --port 4002",
    "emulate:microsoft": "emulate --service microsoft --seed ../../emulate.config.yaml --port 4003",
    "telegram:setup": "dotenv -e .env.local -- tsx scripts/setup-telegram-bot.ts",
    "prisma:migrate:e2e": "dotenv -e .env.e2e -- prisma migrate deploy",
    "prisma:migrate:local": "dotenv -e .env.local -- prisma migrate deploy",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "prisma generate"
  },
