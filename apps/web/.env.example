# GOOGLE_CLIENT_SECRET=emulate-google-secret
# MICROSOFT_EMULATOR_PORT=4003
# MICROSOFT_BASE_URL=http://localhost:4003
# MICROSOFT_CLIENT_ID=emulate-microsoft-client-id
