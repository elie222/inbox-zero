NEXT_PUBLIC_BASE_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:password@localhost:5432/inboxzero?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/inboxzero?schema=public"
# Docker Compose credentials (defaults shown; POSTGRES_PASSWORD must match DATABASE_URL):
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password # change this for production
# POSTGRES_DB=inboxzero
# Optional Docker Compose host port overrides:
# WEB_PORT=3000
# POSTGRES_PORT=5432
# REDIS_PORT=6380
# REDIS_HTTP_PORT=8079

UPSTASH_REDIS_URL="http://localhost:8079"
UPSTASH_REDIS_TOKEN= # openssl rand -hex 32
REDIS_URL= # used for subscriptions and BullMQ worker: rediss://:password@host:port
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QUEUE_BACKEND= # bullmq | qstash | internal

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC_NAME="projects/abc/topics/xyz"
GOOGLE_PUBSUB_VERIFICATION_TOKEN= # openssl rand -hex 32

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_WEBHOOK_CLIENT_STATE= # openssl rand -hex 32
MICROSOFT_TENANT_ID= # leave empty for "common"

# Slack (optional) — see docs/slack/setup.md
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# NEXT_PUBLIC_SLACK_BOT_NAME=Inbox Zero

# Chat SDK adapters (optional)
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_PASSWORD=
TEAMS_BOT_APP_TENANT_ID=
TELEGRAM_BOT_TOKEN=
# Required when Telegram webhooks are enabled. Used to verify x-telegram-bot-api-secret-token.
TELEGRAM_BOT_SECRET_TOKEN=

AUTH_SECRET= # openssl rand -hex 32
# AUTH_ALLOWED_EMAILS=founder@gmail.com,admin@company.com # Optional self-hosted signup allowlist
# AUTH_ALLOWED_EMAIL_DOMAINS=company.com,subsidiary.org # Optional self-hosted signup domain allowlist
EMAIL_ENCRYPT_SECRET= # openssl rand -hex 32
EMAIL_ENCRYPT_SALT= # openssl rand -hex 16
INTERNAL_API_KEY= # openssl rand -hex 32
API_KEY_SALT= # openssl rand -hex 32
CRON_SECRET= # openssl rand -hex 32 -note: cron disabled if not set

NEXT_PUBLIC_BYPASS_PREMIUM_CHECKS=true
# AUTO_JOIN_ORGANIZATION_ENABLED=true # Self-hosted: auto-add new users to the org
# SSO_LOGIN_ENABLED=true # Show and allow SSO login
# NEXT_PUBLIC_SELF_HOSTED_LOGIN_FOOTER_TEXT= # Self-hosted: override the login footer notice. Set to none to hide it.
# NEXT_PUBLIC_EXTERNAL_API_ENABLED=true # Enable the external API (v1 endpoints, API keys, API key UI)
# NEXT_PUBLIC_WEBHOOK_ACTION_ENABLED=false # Self-hosted: disable outgoing webhook rule actions and webhook secret UI
# NEXT_PUBLIC_DELETE_EMAIL_ACTION_ENABLED=true # Self-hosted: enable delete/trash rule actions
# WEBHOOK_ALLOW_PRIVATE_IPS=true # Self-hosted: allow webhook delivery to private IPs (LAN, Tailscale 100.64.0.0/10). Only the webhook sender honors this flag; unsubscribe-link fetching and the Upstash client stay restricted. SECURITY: disables SSRF protection for webhook calls — only enable on a trusted, single-tenant deployment
# NEXT_PUBLIC_AI_MODEL_SETTINGS_DISABLED=true # Self-hosted: hide user AI model settings and enforce deployment-managed model settings
# AUTO_ENABLE_ORG_ANALYTICS=true # Self-hosted: default new org members to analytics enabled
# NEXT_PUBLIC_CONVERSION_ANALYTICS_SCRIPT_URL= # Optional: private conversion analytics script URL
# CONVERSION_ANALYTICS_SERVER_SECRET= # Optional: shared secret for private conversion analytics POSTs
# DISABLE_LOG_ZOD_ERRORS=true # Uncomment to disable Zod validation error logging
# DIGEST_MAX_SUMMARIES_PER_24H=50
# REASONING_RETENTION_DAYS=90 # Optional: redacts older AI reasoning fields after this many days
# DRAFT_SENT_TEXT_RETENTION_DAYS=14 # Redacts captured sent draft text after this many days
# WEBHOOK_URL=
# INTERNAL_API_URL= # Preferred callback base URL for QStash (when set) and server-side fallback calls

# =============================================================================
# LLM Configuration - Uncomment ONE provider block
# =============================================================================

LLM_API_KEY=

# Role model lists. Format: provider:model
# Add comma-separated entries to any row if you want ordered fallbacks.

