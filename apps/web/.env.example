# Feature flags
# NEXT_PUBLIC_DIGEST_ENABLED=true
# NEXT_PUBLIC_MEETING_BRIEFS_ENABLED=true
# NEXT_PUBLIC_FOLLOW_UP_REMINDERS_ENABLED=true
# NEXT_PUBLIC_INTEGRATIONS_ENABLED=false # beta
# NEXT_PUBLIC_SMART_FILING_ENABLED=false # beta
# NEXT_PUBLIC_CLEANER_ENABLED=false # beta
# NEXT_PUBLIC_BOOKING_LINKS_ENABLED=false # beta
# NEXT_PUBLIC_AUTO_DRAFT_DISABLED=true # set to disable auto-drafting

# OAUTH_PROXY_URL= # For preview deployments to proxy OAuth callbacks
# NEXT_PUBLIC_IMAGE_PROXY_BASE_URL=https://img.getinboxzero.com/proxy # Set this to enable proxying. In production, the web app only rewrites assets when IMAGE_PROXY_SIGNING_SECRET is also set.
# NEXT_PUBLIC_IMAGE_PROXY_USE_APP_ROUTE=false # Set to true for self-hosting when you want Inbox Zero to proxy remote images through its own Next.js API route instead of a separate proxy service.
# IMAGE_PROXY_SIGNING_SECRET= # Shared HMAC secret for signed proxy URLs.
# IS_OAUTH_PROXY_SERVER=false # Set to true on the server that acts as the OAuth proxy (e.g., staging)
# ADDITIONAL_TRUSTED_ORIGINS=https://*.vercel.app # Comma-separated list of trusted origins for CORS (supports wildcards)
# MOBILE_AUTH_ORIGIN=inboxzero:// # Mobile deep-link origin trusted for Better Auth; only used for non-HTTPS callback redirects (local dev)
